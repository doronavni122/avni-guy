# Vector index build (prebuild / pnpm run vector:build)
TAVILY_API_KEY=
OPENAI_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small

# Rate limits (in-process; optional Upstash for production consistency)
RAG_RATE_LIMIT_PER_MINUTE=10
RAG_RATE_LIMIT_LIST_PER_MINUTE=30
RAG_RATE_LIMIT_PER_DAY=200
RAG_GLOBAL_DAILY_CAP=5000
RAG_MAX_QUERY_CHARS=300

# Optional Upstash Redis (recommended on Vercel production)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Set automatically when vector index is built during prebuild
RAG_INDEX_BUILT=false

# Local stdio MCP (scripts/site-mcp-server.mjs) - Cursor mcp.json example:
# "avniguy-site": { "command": "node", "args": ["scripts/site-mcp-server.mjs"], "env": { "SITE_URL": "https://avniguy.co.il" } }
SITE_URL=http://localhost:3001
