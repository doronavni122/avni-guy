---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} גיא אבני. כל הזכויות שמורות.</p>
	<p>
		<a href="/contact">ליצירת קשר מהירה</a>
		<span> | </span>
		<a href="/blog">למאמרים מקצועיים</a>
	</p>
</footer>
<style>
	footer {
		padding: 2rem 1rem 4rem;
		background: linear-gradient(var(--gray-gradient)) no-repeat;
		color: rgb(var(--gray));
		text-align: center;
	}
	p {
		margin: 0.4rem 0;
	}
	footer a {
		text-decoration: none;
		color: rgb(var(--gray));
	}
	footer a:hover {
		color: rgb(var(--gray-dark));
	}
</style>
