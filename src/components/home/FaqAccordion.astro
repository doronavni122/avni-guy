---
import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';

interface FaqItem {
	question: string;
	answer: string;
}

interface Props {
	items: FaqItem[];
}

const { items } = Astro.props;
---

<section id="faq" class="home-anchor-target flex flex-col gap-5 text-right" aria-labelledby="faq-title">
	<div class="flex flex-col gap-2">
		<h2 id="faq-title" class="font-heading text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
			שאלות נפוצות לפני שמתחילים
		</h2>
		<div class="flex flex-wrap justify-end gap-2">
			<span class="inline-flex items-center rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-semibold text-foreground">
				שאלות נפוצות
			</span>
			<span class="inline-flex items-center rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-semibold text-foreground">
				התחלה מהירה
			</span>
		</div>
		<p class="max-w-3xl text-sm leading-relaxed text-muted-foreground sm:text-base">
			התשובות הבאות נועדו להסיר חסמים ראשוניים ולתת לכם ודאות לגבי הצעד הראשון.
		</p>
	</div>
	<div class="grid gap-3">
		{
			items.map((item) => (
				<details class="rounded-xl border border-border/60 bg-card/70 p-4 shadow-sm open:border-primary/30 open:bg-primary/5">
					<summary class="cursor-pointer list-none font-semibold text-foreground [&::-webkit-details-marker]:hidden">
						<span class="inline-flex items-center gap-2">
							<span class="text-primary">+</span>
							<strong>{item.question}</strong>
						</span>
					</summary>
					<p class="mt-3 text-sm leading-relaxed text-muted-foreground">{item.answer}</p>
				</details>
			))
		}
	</div>
	<div>
		<a class={cn(buttonVariants({ size: 'lg' }))} href="/contact">רוצים תשובה מותאמת? צרו קשר</a>
	</div>
</section>
