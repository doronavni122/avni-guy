---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import type { ImageMetadata } from 'astro';
import { SITE_TITLE, SITE_URL, type SiteKeyword } from '../consts';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	keyword: SiteKeyword;
	image?: ImageMetadata | string;
	type?: 'website' | 'article';
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const siteOrigin = Astro.site ?? new URL(SITE_URL);
const canonicalURL = new URL(Astro.url.pathname, siteOrigin);

const FALLBACK_OG_IMAGE = '/images/shared/guy-avni-avni-guy-law-firm-lawyer-og-law-fallback-photo-1.jpg';

const { title, description, keyword, image: imageProp, type = 'website', structuredData } = Astro.props;
const image = imageProp ?? FALLBACK_OG_IMAGE;
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;

function resolveAbsoluteOgImage(img: ImageMetadata | string): string {
	try {
		const base = siteOrigin;
		if (typeof img === 'string') {
			if (img.startsWith('http://') || img.startsWith('https://')) return img;
			return new URL(img.startsWith('/') ? img : `/${img}`, base).toString();
		}
		const src = img.src;
		if (src.startsWith('http://') || src.startsWith('https://')) return src;
		return new URL(src, base).toString();
	} catch (err) {
		console.error('[BaseHead] resolveAbsoluteOgImage failed', err);
		return new URL(FALLBACK_OG_IMAGE, siteOrigin).toString();
	}
}

const ogImageUrl = resolveAbsoluteOgImage(image);
const canonicalHref = canonicalURL.toString();
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" type="image/svg+xml" href="/images/branding/guy-avni-avni-guy-law-firm-lawyer-brand-favicon.svg" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL('rss.xml', Astro.site)}
/>
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index,follow,max-image-preview:large" />
<meta name="keywords" content={keyword} />
<meta name="author" content="גיא אבני" />
<meta name="theme-color" content="#1b4d3e" />
{typeof googleSiteVerification === 'string' && googleSiteVerification.trim() ? (
	<meta name="google-site-verification" content={googleSiteVerification.trim()} />
) : null}
{typeof bingSiteVerification === 'string' && bingSiteVerification.trim() ? (
	<meta name="msvalidate.01" content={bingSiteVerification.trim()} />
) : null}

<Font cssVariable="--font-atkinson" preload />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalHref} />

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalHref} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:locale" content="he_IL" />
<meta property="og:site_name" content={SITE_TITLE} />

<!-- Twitter -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalHref} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={ogImageUrl} />
<script type="application/ld+json" set:html={JSON.stringify({
	'@context': 'https://schema.org',
	'@type': 'WebSite',
	name: SITE_TITLE,
	url: SITE_URL,
	inLanguage: 'he',
	creator: {
		'@type': 'Person',
		name: 'גיא אבני',
	},
})} />
{
	structuredData &&
		(Array.isArray(structuredData) ? structuredData : [structuredData]).map((entry) => (
			<script type="application/ld+json" set:html={JSON.stringify(entry)} />
		))
}
