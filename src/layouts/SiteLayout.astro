---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import type { SiteKeyword } from '../consts';

interface Props {
	title: string;
	description: string;
	keyword: SiteKeyword;
	structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
}

const { title, description, keyword, structuredData } = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl" class="scroll-smooth">
	<head>
		<BaseHead
			title={title}
			description={description}
			keyword={keyword}
			structuredData={structuredData}
		/>
	</head>
	<body class="flex min-h-dvh flex-col antialiased">
		<Header />
		<main class="flex flex-1 flex-col">
			<div class="container mx-auto w-full max-w-6xl flex-1 px-4 py-10 sm:px-6 sm:py-12 lg:py-16">
				<slot />
			</div>
		</main>
		<Footer />
	</body>
</html>
