---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import type { SiteKeyword } from '../consts';

interface Props {
	title: string;
	description: string;
	keyword: SiteKeyword;
}

const { title, description, keyword } = Astro.props;
---

<!doctype html>
<html lang="he" dir="rtl">
	<head>
		<BaseHead title={title} description={description} keyword={keyword} />
	</head>
	<body>
		<Header />
		<main>
			<slot />
		</main>
		<Footer />
	</body>
</html>
