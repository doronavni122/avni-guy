---
import type { CollectionEntry } from 'astro:content';
import { badgeVariants } from '@/components/ui/badge';
import { Card, CardContent, CardDescription, CardFooter, CardHeader } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_URL } from '../consts';
import { cn } from '@/lib/utils';
import { buildBreadcrumbSchema } from '../utils/structured-data';

type Props = CollectionEntry<'blog'>['data'];

const {
	title,
	description,
	pubDate,
	updatedDate,
	metaTitle,
	metaDescription,
	mainKeyword,
	category,
	tags,
	images,
	internalLinks,
} = Astro.props;
---

<html lang="he" dir="rtl" class="scroll-smooth">
	<head>
		<BaseHead
			title={metaTitle ?? title}
			description={metaDescription ?? description}
			keyword={mainKeyword ?? 'גיא אבני'}
			type="article"
			structuredData={[
				buildBreadcrumbSchema([
					{ name: 'דף הבית', path: '/' },
					{ name: 'מאמרים', path: '/blog' },
					{ name: title, path: Astro.url.pathname },
				]),
				{
					'@context': 'https://schema.org',
					'@type': 'Article',
					headline: title,
					description: metaDescription ?? description,
					datePublished: pubDate.toISOString(),
					dateModified: (updatedDate ?? pubDate).toISOString(),
					keywords: [mainKeyword],
					articleSection: category,
					inLanguage: 'he',
					url: new URL(Astro.url.pathname, SITE_URL).toString(),
				},
			]}
		/>
	</head>
	<body class="flex min-h-dvh flex-col antialiased">
		<Header />
		<main class="flex flex-1 flex-col">
			<div class="container mx-auto w-full max-w-6xl flex-1 px-4 py-10 sm:px-6 sm:py-12 lg:py-16">
				<article class="flex flex-col gap-10">
					<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
						{
							images.map((imageItem) => (
								<figure class="group overflow-hidden rounded-xl ring-1 ring-border/60 shadow-sm transition-shadow hover:shadow-md">
									<img
										src={imageItem.src}
										alt={imageItem.alt}
										title={imageItem.title}
										loading="lazy"
										decoding="async"
										class="aspect-[3/2] h-auto w-full object-cover transition-transform duration-300 group-hover:scale-[1.02]"
									/>
								</figure>
							))
						}
					</div>

					<Card className="border-border/60 shadow-sm">
						<CardHeader className="gap-4 text-right">
							<div class="flex flex-col gap-2 text-sm text-muted-foreground">
								<FormattedDate date={pubDate} />
								{
									updatedDate && (
										<p class="text-xs italic">
											עודכן לאחרונה: <FormattedDate date={updatedDate} />
										</p>
									)
								}
							</div>
							<CardDescription className="text-xs font-medium uppercase tracking-wide text-primary">
								{mainKeyword}
							</CardDescription>
							<h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground md:text-4xl">
								{title}
							</h1>
							<div class="flex flex-wrap items-center justify-end gap-2">
								<a
									href={`/categories/${category}/`}
									class={cn(
										badgeVariants({ variant: 'outline' }),
										'no-underline hover:bg-muted',
									)}
								>
									קטגוריה: {category}
								</a>
								{
									tags.map((tag) => (
										<a
											href={`/tags/${tag}/`}
											class={cn(
												badgeVariants({ variant: 'secondary' }),
												'no-underline hover:bg-secondary/80',
											)}
										>
											#{tag}
										</a>
									))
								}
							</div>
						</CardHeader>
						<Separator />
						<CardContent className="pt-6">
							<section class="mb-8 rounded-xl border border-border/50 bg-muted/30 p-4 text-right">
								<h2 class="mb-2 font-heading text-sm font-semibold text-foreground">מקורות תמונה חינמיים</h2>
								<ul class="flex flex-col gap-2 text-sm text-muted-foreground">
									{
										images.map((imageItem) => (
											<li>
												<a
													class="text-primary underline-offset-2 hover:underline"
													href={imageItem.source}
													rel="noopener noreferrer"
													target="_blank"
												>
													{imageItem.source}
												</a>
											</li>
										))
									}
								</ul>
							</section>
							<div
								class="max-w-none space-y-4 text-right text-base leading-relaxed text-foreground [&_a]:font-medium [&_a]:text-primary [&_a]:underline-offset-2 [&_a]:hover:underline [&_h2]:mt-8 [&_h2]:font-heading [&_h2]:text-2xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h3]:mt-6 [&_h3]:font-heading [&_h3]:text-xl [&_h3]:font-semibold [&_p]:text-pretty"
							>
								<slot />
							</div>
						</CardContent>
						<CardFooter className="flex flex-col items-stretch gap-4 border-t border-border/60 bg-muted/20 p-6 text-right">
							<h2 class="font-heading text-lg font-semibold text-foreground">קישורים פנימיים מומלצים</h2>
							<ul class="flex flex-col gap-2 text-sm">
								{
									internalLinks.map((link) => (
										<li>
											<a
												class="font-medium text-primary underline-offset-2 hover:underline"
												href={link}
											>
												{link}
											</a>
										</li>
									))
								}
							</ul>
						</CardFooter>
					</Card>
				</article>
			</div>
		</main>
		<Footer />
	</body>
</html>
