---
import { buttonVariants } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import SiteLayout from '../layouts/SiteLayout.astro';
import { cn } from '@/lib/utils';
import { SITE_CONTACT_EMAIL } from '../consts';
import { buildBreadcrumbSchema } from '../utils/structured-data';

const mailtoHref = `mailto:${SITE_CONTACT_EMAIL}?subject=${encodeURIComponent('פנייה מהאתר')}`;
---

<SiteLayout
	title="אבני גיא - יצירת קשר"
	description="עמוד יצירת קשר של אבני גיא לתיאום פגישה ראשונית, שאלות והכוונה מקצועית."
	keyword="אבני גיא"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'יצירת קשר', path: '/contact' },
	])}
>
	<section class="flex flex-col gap-10 lg:flex-row lg:items-start lg:justify-between lg:gap-14">
		<div class="flex max-w-xl flex-col gap-4 text-right">
			<p class="text-sm font-medium text-primary">אבני גיא</p>
			<h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl">
				אבני גיא - יצירת קשר מקצועית ונוחה
			</h1>
			<p class="text-pretty text-lg leading-relaxed text-muted-foreground">
				אפשר לתאם שיחה ראשונית ולהציג את התמונה המלאה. המטרה היא להבין את הצורך במהירות ולהציע מסלול עבודה ברור.
			</p>
			<Separator className="bg-border/60" />
			<div class="flex flex-col gap-4">
				<h2 class="font-heading text-2xl font-semibold tracking-tight text-foreground">מה להכין לפני פנייה</h2>
				<p class="text-pretty leading-relaxed text-muted-foreground">
					כדאי להכין רקע קצר, מסמכים מרכזיים ושאלות ממוקדות. לפני פנייה מומלץ לעבור על
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">השירותים</a>, לקרוא ב־
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog">בלוג</a>, לבדוק
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/categories">קטגוריות</a>
					ו־
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/tags">תגיות</a>, לעיין ב־
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/about">אודות</a>, לחזור ל־
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/">דף הבית</a>, ולקרוא על
					<a
						class="font-medium text-primary underline-offset-2 hover:underline"
						href="/blog/guy-avni-meeting-preparation-checklist/">הכנה לפגישה</a>.
				</p>
				<h3 class="font-heading text-xl font-semibold text-foreground">ערוץ פנייה</h3>
				<p class="text-pretty leading-relaxed text-muted-foreground">
					ניתן לפנות בדוא״ל — המענה ניתן במסגרת הזמינות המקצועית, בצורה עניינית ומכבדת.
				</p>
			</div>
		</div>

		<Card className="w-full max-w-lg shrink-0 border-border/60 shadow-md lg:sticky lg:top-24">
			<CardHeader className="text-right">
				<CardTitle className="font-heading text-xl">יצירת קשר</CardTitle>
				<CardDescription className="text-pretty">
					כתבו בקצרה את הנושא והמטרה — נחזור עם הצעדים הבאים המתאימים.
				</CardDescription>
			</CardHeader>
			<CardContent className="flex flex-col gap-4 text-right">
				<p class="text-sm leading-relaxed text-muted-foreground">
					<strong class="text-foreground">דוא״ל:</strong>{' '}
					<a class="font-medium text-primary underline-offset-2 hover:underline" href={mailtoHref}>
						{SITE_CONTACT_EMAIL}
					</a>
				</p>
				<p class="text-xs text-muted-foreground">
					ניתן לשנות כתובת יעד בפריסה באמצעות משתנה סביבה <code class="rounded bg-muted px-1">PUBLIC_CONTACT_EMAIL</code>.
				</p>
				<a class={cn(buttonVariants({ className: 'w-full justify-center' }), 'no-underline')} href={mailtoHref}>
					פתיחת דוא״ל
				</a>
			</CardContent>
		</Card>
	</section>
</SiteLayout>
