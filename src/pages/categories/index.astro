---
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getCategories } from '../../utils/content-taxonomy';
import { buildBreadcrumbSchema } from '../../utils/structured-data';

const categories = await getCategories();
---

<SiteLayout
	title="גיא אבני עורך דין | קטגוריות מאמרים לפי תחום"
	description="קטגוריות מאמרים של גיא אבני עורך דין, ניווט מהיר בנושאים, קישורים למאמרים, תגיות, שירותים ויצירת קשר."
	keyword="גיא אבני עורך דין"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'קטגוריות', path: '/categories' },
	])}
>
	<section class="flex flex-col gap-10">
		<div class="flex flex-col gap-4 text-right">
			<p class="text-sm font-medium text-primary">גיא אבני עורך דין</p>
			<h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
				גיא אבני עורך דין - קטגוריות תוכן
			</h1>
			<p class="max-w-3xl text-pretty text-lg leading-relaxed text-muted-foreground">
				כאן אפשר לנווט לפי תחום עניין ולמצוא מאמרים ממוקדים במהירות. מומלץ גם לעבור ל־
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog">מאמרים</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/tags">תגיות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">שירותים</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/about">אודות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/contact">יצירת קשר</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/">דף הבית</a>
				ולכתבה
				<a
					class="font-medium text-primary underline-offset-2 hover:underline"
					href="/blog/guy-avni-legal-planning-basics/">יסודות תכנון משפטי</a>.
			</p>
		</div>

		<Separator className="bg-border/60" />

		<div class="flex flex-col gap-4 text-right">
			<h2 class="font-heading text-2xl font-semibold tracking-tight text-foreground">רשימת קטגוריות</h2>
			<h3 class="text-lg font-medium text-muted-foreground">מעבר מהיר לפי נושא</h3>
		</div>

		<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{
				categories.map((category) => (
					<a class="group block no-underline" href={`/categories/${category}/`}>
						<Card className="border-border/60 bg-card/70 shadow-sm transition-all group-hover:border-primary/25 group-hover:shadow-md">
							<CardHeader className="text-right">
								<CardTitle className="font-heading text-lg transition-colors group-hover:text-primary">
									{category}
								</CardTitle>
							</CardHeader>
							<CardContent className="text-right text-sm text-muted-foreground">מעבר למאמרים בקטגוריה</CardContent>
						</Card>
					</a>
				))
			}
		</div>

		<p class="text-right text-sm text-muted-foreground">
			בחרו קטגוריה אחת, קראו שני מאמרים ברצף, ואז עברו לתגיות כדי להרחיב את נקודת המבט באופן מובנה.
		</p>
	</section>
</SiteLayout>
