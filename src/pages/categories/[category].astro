---
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getSortedPosts } from '../../utils/content-taxonomy';
import { buildBreadcrumbSchema } from '../../utils/structured-data';

export async function getStaticPaths() {
	const posts = await getSortedPosts();
	const categories = [...new Set(posts.map((post) => post.data.category))];
	return categories.map((category) => ({ params: { category } }));
}

const category = Astro.params.category ?? '';
const posts = (await getSortedPosts()).filter((post) => post.data.category === category);
---

<SiteLayout
	title={`אבני גיא - קטגוריה ${category}`}
	description={`עמוד קטגוריה ${category} באתר אבני גיא עם מאמרים מקצועיים בעברית.`}
	keyword="אבני גיא"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'קטגוריות', path: '/categories' },
		{ name: category, path: `/categories/${category}/` },
	])}
>
	<h1>אבני גיא - קטגוריה {category}</h1>
	<p>
		בקטגוריה זו תמצאו תכנים פרקטיים וממוקדים. קישורים נוספים: <a href="/blog">מאמרים</a>,
		<a href="/tags">תגיות</a>, <a href="/services">שירותים</a>, <a href="/about">אודות</a>,
		<a href="/contact">יצירת קשר</a>, <a href="/">דף הבית</a>, ולמאמר
		<a href="/blog/guy-avni-communication-strategy-for-clients/">אסטרטגיית תקשורת</a>.
	</p>
	<h2>מאמרים בקטגוריה</h2>
	<ul>
		{posts.map((post) => <li><a href={`/blog/${post.id}/`}>{post.data.title}</a></li>)}
	</ul>
	<h3>הרחבה חכמה</h3>
	<p>לאחר קריאת המאמרים, עברו לתגיות קשורות כדי לקבל זוויות נוספות ליישום מיידי.</p>
</SiteLayout>
