---
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getSortedPosts } from '../../utils/content-taxonomy';
import { buildBreadcrumbSchema } from '../../utils/structured-data';
import {
	buildCategoryMetaDescription,
	buildCategoryPageTitle,
	getCategoryLabel,
} from '../../utils/taxonomy-labels';

export async function getStaticPaths() {
	const posts = await getSortedPosts();
	const categories = [...new Set(posts.map((post) => post.data.category))];
	return categories.map((category) => ({ params: { category } }));
}

const category = Astro.params.category ?? '';
const categoryHe = getCategoryLabel(category);
const posts = (await getSortedPosts()).filter((post) => post.data.category === category);
---

<SiteLayout
	title={buildCategoryPageTitle(categoryHe)}
	description={buildCategoryMetaDescription(categoryHe)}
	keyword="אבני גיא"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'קטגוריות', path: '/categories' },
		{ name: categoryHe, path: `/categories/${category}/` },
	])}
>
	<section class="flex flex-col gap-10">
		<div class="flex flex-col gap-4 text-right">
			<p class="text-sm font-medium text-primary">אבני גיא</p>
			<h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
				אבני גיא - קטגוריה {categoryHe}
			</h1>
			<p class="max-w-3xl text-pretty text-lg leading-relaxed text-muted-foreground">
				בקטגוריה זו תמצאו תכנים פרקטיים וממוקדים. קישורים משלימים:
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog">מאמרים</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/tags">תגיות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">שירותים</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/about">אודות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/contact">יצירת קשר</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/">דף הבית</a>
				ולמאמר
				<a
					class="font-medium text-primary underline-offset-2 hover:underline"
					href="/blog/guy-avni-communication-strategy-for-clients/">אסטרטגיית תקשורת</a>.
			</p>
		</div>

		<Separator className="bg-border/60" />

		<div class="flex flex-col gap-4 text-right">
			<h2 class="font-heading text-2xl font-semibold tracking-tight text-foreground">מאמרים בקטגוריה</h2>
			<h3 class="text-lg font-medium text-muted-foreground">רשימה מעודכנת</h3>
		</div>

		<div class="grid gap-4 sm:grid-cols-2">
			{
				posts.map((post) => (
					<a class="group block no-underline" href={`/blog/${post.id}/`}>
						<Card className="h-full border-border/60 bg-card/70 shadow-sm transition-all group-hover:border-primary/25 group-hover:shadow-md">
							<CardHeader className="text-right">
								<CardTitle className="font-heading text-base leading-snug transition-colors group-hover:text-primary">
									{post.data.title}
								</CardTitle>
							</CardHeader>
							<CardContent className="text-right text-sm text-muted-foreground">{post.data.description}</CardContent>
						</Card>
					</a>
				))
			}
		</div>

		<p class="text-right text-sm text-muted-foreground">
			לאחר קריאת המאמרים, עברו לתגיות קשורות כדי לקבל זוויות נוספות ליישום מיידי.
		</p>
	</section>
</SiteLayout>
