---
import { buttonVariants } from '@/components/ui/button';
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import SiteLayout from '../layouts/SiteLayout.astro';
import { cn } from '@/lib/utils';
import { buildBreadcrumbSchema, buildOrganizationSchema } from '../utils/structured-data';
import { getCategories, getSortedPosts, getTags } from '../utils/content-taxonomy';
import HomeMiniToc from '../components/home/HomeMiniToc.astro';
import FeaturedArticlesGrid from '../components/home/FeaturedArticlesGrid.astro';
import LatestInsightsStrip from '../components/home/LatestInsightsStrip.astro';
import FaqAccordion from '../components/home/FaqAccordion.astro';

interface PostPreview {
	id: string;
	title: string;
	description: string;
	pubDate: Date;
	category: string;
	tags: string[];
}

let posts: PostPreview[] = [];
try {
	const sortedPosts = await getSortedPosts();
	posts = sortedPosts.map((post) => ({
		id: post.id,
		title: post.data.title,
		description: post.data.description,
		pubDate: post.data.pubDate,
		category: post.data.category,
		tags: post.data.tags,
	}));
} catch (error) {
	console.error('[home:index] failed to load sorted posts', error);
}

let categories: string[] = [];
try {
	categories = await getCategories();
} catch (error) {
	console.error('[home:index] failed to load categories', error);
}

let tags: string[] = [];
try {
	tags = await getTags();
} catch (error) {
	console.error('[home:index] failed to load tags', error);
}

let featuredPosts: PostPreview[] = [];
try {
	featuredPosts = posts.slice(0, 6);
} catch (error) {
	console.error('[home:index] failed to build featured posts', error);
}

let latestPosts: PostPreview[] = [];
try {
	latestPosts = posts.slice(0, 3);
} catch (error) {
	console.error('[home:index] failed to build latest insights posts', error);
}

let popularCategories: Array<{ name: string; count: number }> = [];
try {
	const categoryCountMap = posts.reduce((accumulator, post) => {
		accumulator.set(post.category, (accumulator.get(post.category) ?? 0) + 1);
		return accumulator;
	}, new Map<string, number>());
	popularCategories = [...categoryCountMap.entries()]
		.sort((a, b) => b[1] - a[1])
		.slice(0, 6)
		.map(([name, count]) => ({ name, count }));
	if (popularCategories.length === 0) {
		popularCategories = categories.slice(0, 6).map((name) => ({ name, count: 0 }));
	}
} catch (error) {
	console.error('[home:index] failed to compute popular categories', error);
}

let popularTags: Array<{ name: string; count: number }> = [];
try {
	const tagCountMap = posts.reduce((accumulator, post) => {
		post.tags.forEach((tag) => {
			accumulator.set(tag, (accumulator.get(tag) ?? 0) + 1);
		});
		return accumulator;
	}, new Map<string, number>());
	popularTags = [...tagCountMap.entries()]
		.sort((a, b) => b[1] - a[1])
		.slice(0, 10)
		.map(([name, count]) => ({ name, count }));
	if (popularTags.length === 0) {
		popularTags = tags.slice(0, 10).map((name) => ({ name, count: 0 }));
	}
} catch (error) {
	console.error('[home:index] failed to compute popular tags', error);
}

const postMap = new Map(posts.map((post) => [post.id, post]));

let readingPaths: Array<{ title: string; summary: string; posts: PostPreview[] }> = [];
try {
	const pathSeeds = [
		{
			title: 'קליטה חכמה של לקוח חדש',
			summary: 'מסלול קצר לבניית ציפיות, אמון ותהליך עבודה נקי כבר מהפגישה הראשונה.',
			slugs: ['guy-avni-client-onboarding-framework', 'guy-avni-client-trust-roadmap', 'guy-avni-communication-strategy-for-clients'],
		},
		{
			title: 'ניהול סיכונים לעסק פעיל',
			summary: 'רצף קריאה שנותן מסגרת פרקטית לזיהוי, מניעה ושיפור החלטות לאורך זמן.',
			slugs: ['guy-avni-risk-management-routine', 'guy-avni-contract-review-flow', 'guy-avni-dispute-prevention-method'],
		},
		{
			title: 'שיפור ביצועים בעבודה משפטית',
			summary: 'שלושה מאמרים לבניית שגרה מקצועית מדויקת יותר, תחת עומס ותוך שמירה על איכות.',
			slugs: ['guy-avni-process-improvement-for-legal-teams', 'guy-avni-time-management-for-legal-work', 'guy-avni-service-quality-standards'],
		},
	];

	readingPaths = pathSeeds
		.map((pathSeed) => ({
			title: pathSeed.title,
			summary: pathSeed.summary,
			posts: pathSeed.slugs
				.map((slug) => {
					const post = postMap.get(slug);
					if (!post) {
						console.error(`[home:index] reading path post was not found: ${slug}`);
					}
					return post;
				})
				.filter((post): post is PostPreview => Boolean(post)),
		}))
		.filter((pathSeed) => pathSeed.posts.length > 0);
} catch (error) {
	console.error('[home:index] failed to build reading paths', error);
}

const tocItems = [
	{ id: 'quick-start', label: 'מסלול התחלה מהיר' },
	{ id: 'process', label: 'איך התהליך עובד בפועל' },
	{ id: 'authority', label: 'למה לעבוד עם גיא אבני' },
	{ id: 'audience', label: 'למי זה מתאים?' },
	{ id: 'comparison', label: 'לטפל לבד או עם ליווי משפטי' },
	{ id: 'long-form-content', label: 'מדריכי עומק' },
	{ id: 'latest-insights', label: 'תובנות אחרונות' },
	{ id: 'faq', label: 'שאלות נפוצות' },
];

const quickStartLinks = [
	{ label: 'אודות', href: '/about' },
	{ label: 'שירותים', href: '/services' },
	{ label: 'מאמרים', href: '/blog' },
	{ label: 'קטגוריות', href: '/categories' },
	{ label: 'תגיות', href: '/tags' },
	{ label: 'יצירת קשר', href: '/contact' },
];

const processSteps = [
	{ title: 'מגדירים מטרה', text: 'מבהירים מה חשוב לכם עכשיו ומה ייחשב הצלחה בטווח המיידי והרחוק.' },
	{ title: 'ממפים סיכון והזדמנות', text: 'מזהים פערים, נקודות רגישות והזדמנויות לשיפור לפני שמבצעים מהלך.' },
	{ title: 'בונים תוכנית פעולה', text: 'מסדרים סדר עדיפויות, אחריות ולוחות זמנים כדי להתקדם בלי רעש מיותר.' },
	{ title: 'מבצעים ומדייקים', text: 'מתקדמים בצעדים מדידים, בוחנים תוצאות ומעדכנים החלטות לפי הצורך.' },
];

const faqItems = [
	{
		question: 'איך יודעים אם צריך ייעוץ כבר עכשיו?',
		answer:
			'אם יש החלטה עם השלכה כספית, חוזית או תפעולית, עדיף לעצור לבדיקה קצרה לפני פעולה. ייעוץ מוקדם לרוב חוסך זמן, כסף ומחלוקות.',
	},
	{
		question: 'מה להכין לפני שיחת היכרות?',
		answer:
			'כדאי להביא תיאור קצר של המצב, מסמכים רלוונטיים ושתי מטרות ברורות. כך אפשר להגיע להמלצה ממוקדת כבר בשיחה הראשונה.',
	},
	{
		question: 'האם הליווי מתאים גם לעסקים קטנים?',
		answer:
			'כן. המודל נבנה כך שיתאים גם לעסקים בתנועה מהירה: הגדרת עדיפויות, שלבים ברורים ושגרה פרקטית שמפחיתה סיכון לאורך זמן.',
	},
	{
		question: 'איך נראה הצעד הראשון אחרי יצירת קשר?',
		answer:
			'מתבצעת שיחת מיקוד קצרה, אחריה מקבלים תמונת מצב, המלצה אופרטיבית ומסלול פעולה שמתאים ליכולת וליעד שלכם.',
	},
];

const homeImages = [
	{
		src: '/images/home/guy-avni-avni-guy-law-firm-lawyer-suite-man-portrait-office-photo-1.jpg',
		alt: 'Guy Avni Avni Guy law firm lawyer suite man portrait office photo 1 - פורטרט מקצועי בחליפת עסקים במשרד',
		title: 'Guy Avni Avni Guy law firm lawyer suite man portrait office photo 1',
	},
	{
		src: '/images/home/guy-avni-avni-guy-law-firm-lawyer-office-meeting-photo-2.jpg',
		alt: 'Guy Avni Avni Guy law firm lawyer office meeting photo 2 - פגישת עבודה מקצועית בסביבת משרד',
		title: 'Guy Avni Avni Guy law firm lawyer office meeting photo 2',
	},
	{
		src: '/images/home/guy-avni-avni-guy-law-firm-lawyer-office-team-photo-3.jpg',
		alt: 'Guy Avni Avni Guy law firm lawyer office team photo 3 - צוות במשרד בעבודת תיאום משפטית',
		title: 'Guy Avni Avni Guy law firm lawyer office team photo 3',
	},
	{
		src: '/images/home/guy-avni-avni-guy-law-firm-lawyer-boardroom-photo-4.jpg',
		alt: 'Guy Avni Avni Guy law firm lawyer boardroom photo 4 - חדר ישיבות מקצועי בסביבת משרד',
		title: 'Guy Avni Avni Guy law firm lawyer boardroom photo 4',
	},
	{
		src: '/images/home/guy-avni-avni-guy-law-firm-lawyer-executive-portrait-photo-5.jpg',
		alt: 'Guy Avni Avni Guy law firm lawyer executive portrait photo 5 - פורטרט מנהל בחליפה במשרד',
		title: 'Guy Avni Avni Guy law firm lawyer executive portrait photo 5',
	},
	{
		src: '/images/home/guy-avni-avni-guy-law-firm-lawyer-office-workspace-photo-6.jpg',
		alt: 'Guy Avni Avni Guy law firm lawyer office workspace photo 6 - סביבת עבודה משרדית לעבודה משפטית',
		title: 'Guy Avni Avni Guy law firm lawyer office workspace photo 6',
	},
	{
		src: '/images/home/guy-avni-avni-guy-law-firm-lawyer-suite-portrait-photo-7.jpg',
		alt: 'Guy Avni Avni Guy law firm lawyer suite portrait photo 7 - פורטרט נוסף בחליפה בסביבת משרד',
		title: 'Guy Avni Avni Guy law firm lawyer suite portrait photo 7',
	},
];
---

<SiteLayout
	title="גיא אבני | בית למאמרים משפטיים וליווי מקצועי"
	description="גיא אבני מרכז כאן מאמרים משפטיים בעברית, שירותים לפרטיים ולעסקים, ומסלול ברור לפגישת ייעוץ ראשונה בעורך הדין."
	keyword="גיא אבני"
	structuredData={[
		buildOrganizationSchema(),
		buildBreadcrumbSchema([{ name: 'דף הבית', path: '/' }]),
	]}
>
	<section class="relative flex flex-col gap-10 pb-24 lg:gap-14 md:pb-6">
		<div
			class="relative overflow-hidden rounded-2xl border border-border/60 bg-card/80 p-8 shadow-sm ring-1 ring-primary/10 sm:p-10 lg:p-12"
		>
			<div
				class="pointer-events-none absolute inset-0 bg-[radial-gradient(800px_circle_at_0%_0%,oklch(0.45_0.08_165/0.12),transparent_55%)]"
				aria-hidden="true"
			/>
			<div class="relative flex flex-col gap-6 text-right">
				<p class="text-sm font-medium tracking-wide text-primary">גיא אבני · משרד עורכי דין</p>
				<h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
					גיא אבני - תוכן מקצועי ושירות משפטי ברור
				</h1>
				<p class="max-w-2xl text-pretty text-base leading-relaxed text-muted-foreground sm:text-lg">
					ברוכים הבאים לאתר של גיא אבני. כאן תמצאו תכנים ברורים בשפה פשוטה, יחד עם גישה חיובית ופתרונות
					פרקטיים ללקוחות פרטיים ועסקיים.
				</p>
				<div class="flex flex-wrap items-center justify-end gap-3">
					<a class={cn(buttonVariants({ size: 'lg' }))} href="/contact">תיאום שיחה</a>
					<a class={cn(buttonVariants({ variant: 'outline', size: 'lg' }))} href="/blog">למאמרים</a>
				</div>
				<figure class="overflow-hidden rounded-xl border border-border/60 bg-background/80">
					<img
						src={homeImages[0].src}
						alt={homeImages[0].alt}
						title={homeImages[0].title}
						loading="eager"
						width="1400"
						height="900"
						class="h-56 w-full object-cover sm:h-64"
					/>
				</figure>
			</div>
		</div>

		<HomeMiniToc items={tocItems} />

		<section id="quick-start" class="home-anchor-target flex flex-col gap-4 text-right" aria-labelledby="quick-start-title">
			<h2 id="quick-start-title" class="font-heading text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
				מסלול התחלה מהיר
			</h2>
			<div class="flex flex-wrap justify-end gap-2">
				<span class="inline-flex items-center rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-semibold text-foreground">
					ניווט חכם
				</span>
				<span class="inline-flex items-center rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-semibold text-foreground">
					פעולות מומלצות
				</span>
			</div>
			<p class="max-w-3xl text-pretty text-muted-foreground leading-relaxed">
				רוצים להתמצא באתר בדקה? התחילו במסלול המומלץ: הכירו את
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/about">הגישה המקצועית</a>,
				עברו לעמוד
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">השירותים</a>,
				דפדפו ב־
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog">מאמרים</a>,
				ואז העמיקו דרך
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/categories">קטגוריות</a>
				ו־
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/tags">תגיות</a>.
				אם תרצו יישום מיידי למצב שלכם, סיימו בעמוד
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/contact">יצירת קשר</a>.
			</p>
			<ul class="max-w-3xl list-disc space-y-2 pr-5 text-sm leading-relaxed text-muted-foreground">
				<li>
					<strong class="text-foreground">שלב 1:</strong> הכירו את
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/about">הרקע והגישה</a>
					לפני כל החלטה.
				</li>
				<li>
					<strong class="text-foreground">שלב 2:</strong> מיינו נושא דרך
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog">מאמרים</a>,
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/categories">קטגוריות</a>
					ו־
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/tags">תגיות</a>.
				</li>
				<li>
					<strong class="text-foreground">שלב 3:</strong> עברו ליישום מעשי עם
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/contact">פנייה ממוקדת</a>.
				</li>
			</ul>
			<div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
				{
					quickStartLinks.map((link) => (
						<a class="rounded-xl border border-border/60 bg-card/70 px-4 py-3 text-sm font-semibold text-foreground transition-colors hover:border-primary/30 hover:text-primary" href={link.href}>
							{link.label}
						</a>
					))
				}
			</div>
			<figure class="overflow-hidden rounded-xl border border-border/60 bg-background/80">
				<img
					src={homeImages[1].src}
					alt={homeImages[1].alt}
					title={homeImages[1].title}
					loading="lazy"
					width="1400"
					height="900"
					class="h-52 w-full object-cover sm:h-60"
				/>
			</figure>
		</section>

		<div class="grid gap-6 lg:grid-cols-3">
			<Card className="border-border/60 bg-card/70 shadow-sm backdrop-blur-sm">
				<CardHeader className="text-right">
					<CardTitle className="font-heading text-lg">בהירות מהירה</CardTitle>
					<CardDescription className="text-pretty">
						מסלולי עבודה מסודרים, שפה נקייה והתמקדות בתוצאה טובה לטווח ארוך.
					</CardDescription>
				</CardHeader>
			</Card>
			<Card className="border-border/60 bg-card/70 shadow-sm backdrop-blur-sm">
				<CardHeader className="text-right">
					<CardTitle className="font-heading text-lg">שירות פרימיום</CardTitle>
					<CardDescription className="text-pretty">
						ליווי מקצועי עם דגש על זמינות, אחריות ותיאום ציפיות מוקדם.
					</CardDescription>
				</CardHeader>
			</Card>
			<Card className="border-border/60 bg-card/70 shadow-sm backdrop-blur-sm">
				<CardHeader className="text-right">
					<CardTitle className="font-heading text-lg">תוכן מעשי</CardTitle>
					<CardDescription className="text-pretty">
						מאמרים וכלים שמחברים בין משפט ליישום יומיומי בצורה חיובית.
					</CardDescription>
				</CardHeader>
			</Card>
		</div>

		<Separator className="bg-border/60" />

		<section id="process" class="home-anchor-target flex flex-col gap-6 text-right" aria-labelledby="process-title">
			<h2 id="process-title" class="font-heading text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
				איך התהליך עובד בפועל
			</h2>
			<div class="flex flex-wrap justify-end gap-2">
				<span class="inline-flex items-center rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-semibold text-foreground">
					שיטה מודולרית
				</span>
				<span class="inline-flex items-center rounded-full border border-border/60 bg-background/80 px-3 py-1 text-xs font-semibold text-foreground">
					מדידה ושיפור
				</span>
			</div>
			<p class="max-w-3xl text-pretty text-muted-foreground leading-relaxed">
				כדי להפוך תהליך משפטי למשהו ברור ומרגיע, חשוב לעבוד בסדר קבוע: מטרה, מיפוי, תוכנית וביצוע. כך מצמצמים אי־ודאות,
				מונעים טעויות יקרות ומתקדמים בקצב נכון לעסק או למשפחה.
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">לעמוד השירותים המלא</a>.
			</p>
			<ul class="max-w-3xl list-disc space-y-2 pr-5 text-sm leading-relaxed text-muted-foreground">
				<li>
					<strong class="text-foreground">פחות אי־ודאות:</strong> כל שלב מוגדר מראש עם
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">תוצר ברור</a>.
				</li>
				<li>
					<strong class="text-foreground">יותר שליטה:</strong> תיעדוף נכון של משימות לפי
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog/guy-avni-risk-management-routine/">השפעה וסיכון</a>.
				</li>
				<li>
					<strong class="text-foreground">קצב יציב:</strong> התקדמות עקבית בלי
					<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog/guy-avni-process-improvement-for-legal-teams/">עומס החלטות מיותר</a>.
				</li>
			</ul>
			<div class="grid gap-4 md:grid-cols-2">
				{
					processSteps.map((step, index) => (
						<Card className="border-border/60 bg-card/70 shadow-sm">
							<CardHeader className="text-right">
								<CardDescription className="text-xs font-semibold text-primary">שלב {index + 1}</CardDescription>
								<CardTitle className="font-heading text-lg">{step.title}</CardTitle>
							</CardHeader>
							<CardContent className="text-right">
								<p class="text-sm leading-relaxed text-muted-foreground">{step.text}</p>
							</CardContent>
						</Card>
					))
				}
			</div>
			<figure class="overflow-hidden rounded-xl border border-border/60 bg-background/80">
