---
import SiteLayout from '../../layouts/SiteLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getSortedPosts } from '../../utils/content-taxonomy';
import { buildBreadcrumbSchema } from '../../utils/structured-data';

const posts = await getSortedPosts();
---

<SiteLayout
	title="אבני גיא עוד - מאמרים מקצועיים"
	description="עמוד המאמרים של אבני גיא עוד עם תכנים מקצועיים, חיוביים ומעודכנים."
	keyword="אבני גיא עוד"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'מאמרים', path: '/blog' },
	])}
>
	<h1>אבני גיא עוד - מאמרים מקצועיים בעברית</h1>
	<p>
		עמוד זה מרכז את כל המאמרים לפי סדר עדכני. ניתן לקפוץ גם ל־<a href="/categories">קטגוריות</a>,
		<a href="/tags">תגיות</a>, <a href="/services">שירותים</a>, <a href="/about">אודות</a>,
		<a href="/contact">יצירת קשר</a>, <a href="/">דף הבית</a> ולמאמר
		<a href="/blog/guy-avni-client-trust-roadmap/">מפת אמון לקוח</a>.
	</p>
	<h2>רשימת מאמרים</h2>
	<ul>
		{
			posts.map((post) => (
				<li>
					<a href={`/blog/${post.id}/`}>{post.data.title}</a>
					<span> - </span>
					<FormattedDate date={post.data.pubDate} />
				</li>
			))
		}
	</ul>
	<h3>איך להתקדם מכאן</h3>
	<p>
		בחרו מאמר אחד להתחלה, ואז עברו לפי קישורי ההמשך בכל עמוד כדי לבנות תמונת מצב מלאה ופרקטית.
	</p>
</SiteLayout>
