---
import { Card, CardContent, CardDescription, CardHeader, CardTitle } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import SiteLayout from '../../layouts/SiteLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { getSortedPosts } from '../../utils/content-taxonomy';
import { buildBreadcrumbSchema } from '../../utils/structured-data';

const posts = await getSortedPosts();
---

<SiteLayout
	title="אבני גיא עוד - מאמרים מקצועיים"
	description="עמוד המאמרים של אבני גיא עוד עם תכנים מקצועיים, חיוביים ומעודכנים."
	keyword="אבני גיא עוד"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'מאמרים', path: '/blog' },
	])}
>
	<section class="flex flex-col gap-10">
		<div class="flex flex-col gap-4 text-right">
			<p class="text-sm font-medium text-primary">אבני גיא עוד</p>
			<h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
				אבני גיא עוד - מאמרים מקצועיים בעברית
			</h1>
			<p class="max-w-3xl text-pretty text-lg leading-relaxed text-muted-foreground">
				עמוד זה מרכז את כל המאמרים לפי סדר עדכני. ניתן לקפוץ גם ל־
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/categories">קטגוריות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/tags">תגיות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">שירותים</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/about">אודות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/contact">יצירת קשר</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/">דף הבית</a>
				ולמאמר
				<a
					class="font-medium text-primary underline-offset-2 hover:underline"
					href="/blog/guy-avni-client-trust-roadmap/">מפת אמון לקוח</a>.
			</p>
		</div>

		<Separator className="bg-border/60" />

		<div class="flex flex-col gap-4 text-right">
			<h2 class="font-heading text-2xl font-semibold tracking-tight text-foreground">רשימת מאמרים</h2>
			<h3 class="text-lg font-medium text-muted-foreground">בחירה מהירה לפי נושא</h3>
		</div>

		<div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-3">
			{
				posts.map((post) => (
					<a class="group block h-full no-underline" href={`/blog/${post.id}/`}>
						<Card className="h-full border-border/60 bg-card/70 shadow-sm transition-all group-hover:-translate-y-0.5 group-hover:border-primary/25 group-hover:shadow-md">
							<CardHeader className="text-right">
								<CardDescription className="text-xs text-muted-foreground">
									<FormattedDate date={post.data.pubDate} />
								</CardDescription>
								<CardTitle className="font-heading text-base leading-snug transition-colors group-hover:text-primary">
									{post.data.title}
								</CardTitle>
							</CardHeader>
							<CardContent className="text-right">
								<p class="line-clamp-3 text-sm leading-relaxed text-muted-foreground">{post.data.description}</p>
							</CardContent>
						</Card>
					</a>
				))
			}
		</div>

		<p class="text-right text-sm text-muted-foreground">
			בחרו מאמר אחד להתחלה, ואז עברו לפי קישורי ההמשך בכל עמוד כדי לבנות תמונת מצב מלאה ופרקטית.
		</p>
	</section>
</SiteLayout>
