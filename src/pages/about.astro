---
import SiteLayout from '../layouts/SiteLayout.astro';
import { buildBreadcrumbSchema } from '../utils/structured-data';
---

<SiteLayout
	title="גיא אבני עוד - אודות"
	description="עמוד אודות של גיא אבני עוד עם רקע מקצועי, ערכים ודרך עבודה חיובית."
	keyword="גיא אבני עוד"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'אודות', path: '/about' },
	])}
>
	<h1>גיא אבני עוד - ניסיון, אחריות וראייה קדימה</h1>
	<p>
		אני פועל מתוך אמונה ששירות משפטי צריך להיות אנושי, ברור וממוקד תוצאה. לאורך השנים בניתי תהליך
		עבודה שמצמצם אי-ודאות ומאפשר ללקוח להתקדם בביטחון.
	</p>

	<h2>ערכי העבודה שמובילים את גיא אבני עוד</h2>
	<p>
		העבודה שלי נשענת על שקיפות, זמינות וחשיבה אסטרטגית. אפשר להעמיק דרך עמוד
		<a href="/services">השירותים</a>, לקרוא את <a href="/blog">הבלוג</a>, לעיין ב־<a href="/categories">קטגוריות</a>,
		לנווט לפי <a href="/tags">תגיות</a>, לבדוק את <a href="/">דף הבית</a>, לעבור ל־
		<a href="/contact">יצירת קשר</a> ולקרוא על <a href="/blog/guy-avni-document-readiness-guide/">מוכנות מסמכים</a>.
	</p>

	<h3>למי זה מתאים</h3>
	<p>
		האתר מתאים למי שמחפש ליווי מקצועי בשפה פרקטית, עם דגש על תכנון מוקדם, צעדים ישימים ותוכן חיובי
		שמחבר בין ידע משפטי לבין החלטות יומיומיות.
	</p>
</SiteLayout>
