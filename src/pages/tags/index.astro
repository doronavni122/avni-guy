---
import { Card, CardHeader, CardTitle } from '@/components/ui/card';
import { Separator } from '@/components/ui/separator';
import SiteLayout from '../../layouts/SiteLayout.astro';
import { getTags } from '../../utils/content-taxonomy';
import { buildBreadcrumbSchema } from '../../utils/structured-data';
import { getTagLabel } from '../../utils/taxonomy-labels';

const tags = await getTags();
---

<SiteLayout
	title="גיא אבני משרד עורכי דין | תגיות לנושאים ממוקדים"
	description="תגיות תוכן באתר גיא אבני משרד עורכי דין, דיוק מהיר בנושא, קישורים למאמרים, קטגוריות, שירותים ואודות המשרד."
	keyword="גיא אבני משרד עורכי דין"
	structuredData={buildBreadcrumbSchema([
		{ name: 'דף הבית', path: '/' },
		{ name: 'תגיות', path: '/tags' },
	])}
>
	<section class="flex flex-col gap-10">
		<div class="flex flex-col gap-4 text-right">
			<p class="text-sm font-medium text-primary">גיא אבני משרד עורכי דין</p>
			<h1 class="font-heading text-3xl font-semibold tracking-tight text-foreground sm:text-4xl lg:text-5xl">
				גיא אבני משרד עורכי דין - תגיות תוכן
			</h1>
			<p class="max-w-3xl text-pretty text-lg leading-relaxed text-muted-foreground">
				דף התגיות מאפשר לכם לדייק את החיפוש לפי נושאים נקודתיים. מומלץ לעבור גם על
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/categories">קטגוריות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/blog">מאמרים</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/services">שירותים</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/about">אודות</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/contact">יצירת קשר</a>,
				<a class="font-medium text-primary underline-offset-2 hover:underline" href="/">דף הבית</a>
				והמאמר
				<a
					class="font-medium text-primary underline-offset-2 hover:underline"
					href="/blog/guy-avni-process-improvement-for-legal-teams/">שיפור תהליכים</a>.
			</p>
		</div>

		<Separator className="bg-border/60" />

		<div class="flex flex-col gap-4 text-right">
			<h2 class="font-heading text-2xl font-semibold tracking-tight text-foreground">כל התגיות</h2>
			<h3 class="text-lg font-medium text-muted-foreground">ניווט מהיר</h3>
		</div>

		<div class="flex flex-wrap justify-end gap-3">
			{
				tags.map((tag) => (
					<a class="no-underline" href={`/tags/${tag}/`}>
						<Card className="border-border/60 bg-card/70 px-4 py-3 shadow-sm transition-all hover:border-primary/25 hover:shadow-md">
							<CardHeader className="p-0 text-right">
								<CardTitle className="font-heading text-sm font-semibold text-primary">{getTagLabel(tag)}</CardTitle>
							</CardHeader>
						</Card>
					</a>
				))
			}
		</div>

		<p class="text-right text-sm text-muted-foreground">
			בחרו שתי תגיות סמוכות לעבודה, השוו בין התכנים שלהן, וצרו לעצמכם סדר פעולות ברור להמשך.
		</p>
	</section>
</SiteLayout>
