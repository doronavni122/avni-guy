{
	"framework": "nextjs",
	"installCommand": "pnpm install --frozen-lockfile",
	"buildCommand": "pnpm run build:ci",
	"trailingSlash": true,
	"redirects": [
		{
			"source": "/:path*",
			"has": [{ "type": "host", "value": "avni-guy.vercel.app" }],
			"destination": "https://avniguy.co.il/:path*",
			"permanent": true
		},
		{
			"source": "/:path*",
			"has": [{ "type": "host", "value": "www.avniguy.co.il" }],
			"destination": "https://avniguy.co.il/:path*",
			"permanent": true
		}
	]
}
