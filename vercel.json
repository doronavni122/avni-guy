{
	"framework": "astro",
	"buildCommand": "pnpm build",
	"installCommand": "pnpm install --frozen-lockfile",
	"outputDirectory": "dist",
	"cleanUrls": true,
	"trailingSlash": false,
	"redirects": [
		{
			"source": "/(.*)",
			"has": [{ "type": "host", "value": "avni-guy.vercel.app" }],
			"destination": "https://www.avniguy.co.il/$1",
			"permanent": true
		}
	]
}
