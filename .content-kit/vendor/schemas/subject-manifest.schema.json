{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "SubjectManifest",
  "type": "object",
  "required": ["subjects"],
  "properties": {
    "date": { "type": "string", "format": "date" },
    "subjects": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["nnnn", "label", "slug", "contentFile"],
        "properties": {
          "nnnn": { "type": "string", "pattern": "^\\d{4}$" },
          "label": { "type": "string" },
          "slug": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
          "contentFile": { "type": "string" },
          "internalLinkManifest": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
