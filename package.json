{
  "name": "avni-guy",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "predev": "node scripts/check-dev-port.mjs",
    "dev": "next dev -p 3001",
    "images:optimize": "node scripts/optimize-images.mjs",
    "prebuild": "node scripts/optimize-images.mjs",
    "build": "next build",
    "build:ci": "pnpm run build && node scripts/check-performance-budget.mjs && pnpm run smoke:routes",
    "start": "next start",
    "smoke:routes": "node scripts/smoke-routes.mjs",
    "smoke:production": "node scripts/smoke-production.mjs",
    "mcp:site": "node scripts/site-mcp-server.mjs",
    "cms:dev": "KEYSTATIC_STORAGE_KIND=local next dev -p 3001",
    "hooks:install": "node scripts/tools/install-git-hooks.cjs",
    "atomic:validate-staged": "node scripts/tools/validate-atomic-change-logging.cjs --staged",
    "atomic:validate-range": "node scripts/tools/validate-atomic-change-logging.cjs --range"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@keystatic/core": "^0.5.50",
    "@keystatic/next": "^5.0.4",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fast-glob": "^3.3.3",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.14.0",
    "next": "^15.5.7",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "shadcn": "^4.6.0",
    "sharp": "^0.34.3",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^22.19.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.9.3"
  }
}
